  "keyFeatures": [
    "High-performance JavaScript/TypeScript parser with full ES2024+ support",
    "ESLint-compatible linter (oxlint) with 200+ built-in rules",
    "Fast code formatter (oxfmt) compatible with Prettier",
    "Code transformer for TypeScript, JSX, and modern JavaScript",
    "JavaScript minifier with dead code elimination and constant folding",
    "Module resolver for Node.js-style resolution",
    "Modular architecture - use components independently or together",
    "Available as Rust crates and Node.js packages (NAPI bindings)"
  ],
  "publicApiSurface": [
    "oxlint - CLI linter with ESLint compatibility",
    "oxfmt - CLI formatter with Prettier compatibility",
    "oxc-parser - Node.js parser API (parseSync)",
    "oxc-transform - Node.js transformation API (transform)",
    "oxc-minify - Node.js minification API (minify)",
    "oxc_parser - Rust parser crate",
    "oxc_semantic - Rust semantic analysis crate",
    "oxc_linter - Rust linter engine crate",
    "oxc_transformer - Rust transformer crate",
    "oxc_minifier - Rust minifier crate",
    "oxc_codegen - Rust code generator crate",
    "oxc_ast - Rust AST definitions crate",
    "oxc_allocator - Rust arena allocator crate"
  ]
